# Same as Caddyfile but for Caddy running inside Docker Compose (same network as `frontend`).
# Use with: docker compose -f docker-compose.yml -f deploy/docker-compose.caddy.yml up -d

{
	# email admin@encipherhealth.com
}

opspilot.encipherhealth.com {
	encode gzip zstd

	reverse_proxy frontend:80 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
